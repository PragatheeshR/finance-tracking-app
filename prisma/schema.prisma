// Finance Tracker - Prisma Schema
// Complete database schema for personal finance tracking application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User Management & Authentication
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  idealAllocations  IdealAllocation[]
  holdings          Holding[]
  snapshots         Snapshot[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  budgetItems       BudgetItem[]
  insurancePolicies InsurancePolicy[]
  userSettings      UserSettings?
  recurringExpenses RecurringExpense[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// User Settings & Preferences
// ============================================================================

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  currency           String   @default("INR")
  timezone           String   @default("Asia/Kolkata")
  dateFormat         String   @default("DD/MM/YYYY")
  fireNumber         Decimal  @default(0) @db.Decimal(15, 2)
  fireMultiplier     Int      @default(28)
  theme              String   @default("light")
  notifications      Json     @default("{}")
  onboardingComplete Boolean  @default(false)
  showEmptyStates    Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================================================
// Asset Categories & Templates
// ============================================================================

model AssetCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  displayName String
  type        AssetType
  icon        String?
  color       String?
  sortOrder   Int       @default(0)
  isDefault   Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  idealAllocations IdealAllocation[]
  holdings         Holding[]

  @@map("asset_categories")
}

enum AssetType {
  ASSET
  LIABILITY
}

model AllocationTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  allocations Json
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("allocation_templates")
}

// ============================================================================
// Ideal Allocation
// ============================================================================

model IdealAllocation {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  percentage Decimal  @db.Decimal(5, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category AssetCategory @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
  @@map("ideal_allocations")
}

// ============================================================================
// Holdings (Stocks, MF, etc.)
// ============================================================================

model Holding {
  id              String    @id @default(cuid())
  userId          String
  categoryId      String
  name            String
  symbol          String?
  subCategory     String?
  units           Decimal   @db.Decimal(15, 4)
  unitPrice       Decimal   @db.Decimal(15, 2)
  investedAmount  Decimal   @db.Decimal(15, 2)
  currentAmount   Decimal   @db.Decimal(15, 2)
  profitLoss      Decimal   @db.Decimal(15, 2)
  allocationPct   Decimal   @db.Decimal(5, 4)
  purchaseDate    DateTime?
  remarks         String?   @db.Text
  lastPriceUpdate DateTime?
  autoFetchPrice  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category AssetCategory @relation(fields: [categoryId], references: [id])

  @@index([userId, categoryId])
  @@index([symbol])
  @@map("holdings")
}

// ============================================================================
// Snapshots (Historical Networth)
// ============================================================================

model Snapshot {
  id            String   @id @default(cuid())
  userId        String
  snapshotDate  DateTime
  totalNetworth Decimal  @db.Decimal(15, 2)
  snapshotData  Json
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snapshotDate])
  @@map("snapshots")
}

// ============================================================================
// Expense Categories (User-Defined)
// ============================================================================

model ExpenseCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  icon      String?
  color     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("expense_categories")
}

// ============================================================================
// Expenses
// ============================================================================

model Expense {
  id          String     @id @default(cuid())
  userId      String
  date        DateTime
  bucketType  BucketType
  category    String
  description String
  amount      Decimal    @db.Decimal(15, 2)
  tags        String[]   @default([])
  receiptUrl  String?
  isRecurring Boolean    @default(false)
  recurringId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, bucketType])
  @@index([userId, category])
  @@map("expenses")
}

enum BucketType {
  FIXED
  VARIABLE
  IRREGULAR
}

model RecurringExpense {
  id            String     @id @default(cuid())
  userId        String
  bucketType    BucketType
  category      String
  description   String
  amount        Decimal    @db.Decimal(15, 2)
  frequency     String
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean    @default(true)
  lastGenerated DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("recurring_expenses")
}

// ============================================================================
// Budget
// ============================================================================

model BudgetItem {
  id            String   @id @default(cuid())
  userId        String
  category      String
  monthlyAmount Decimal  @db.Decimal(15, 2)
  year          Int
  month         Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, year, month])
  @@index([userId, year, month])
  @@map("budget_items")
}

// ============================================================================
// Insurance
// ============================================================================

model InsurancePolicy {
  id             String     @id @default(cuid())
  userId         String
  policyName     String
  policyType     PolicyType
  policyNumber   String?
  validTill      DateTime?
  premiumAmount  Decimal?   @db.Decimal(15, 2)
  premiumDueDate DateTime?
  amountInsured  Decimal?   @db.Decimal(15, 2)
  nominee        String?
  remarks        String?    @db.Text
  documentUrl    String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, policyType])
  @@index([userId, premiumDueDate])
  @@map("insurance_policies")
}

enum PolicyType {
  HEALTH
  LIFE
  CAR
  BIKE
  OTHER
}

// ============================================================================
// Market Data Cache
// ============================================================================

model MarketDataCache {
  id        String   @id @default(cuid())
  symbol    String   @unique
  price     Decimal  @db.Decimal(15, 2)
  currency  String   @default("INR")
  source    String
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([symbol, expiresAt])
  @@map("market_data_cache")
}

// ============================================================================
// Audit Logs
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
